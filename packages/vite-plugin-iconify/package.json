{
	"name": "@questpie/vite-plugin-iconify",
	"version": "0.0.1",
	"description": "Vite plugin that auto-bundles only the Iconify icons you use",
	"repository": {
		"type": "git",
		"url": "https://github.com/questpie/questpie.git",
		"directory": "packages/vite-plugin-iconify"
	},
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"exports": {
		".": "./src/index.ts"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			}
		}
	},
	"scripts": {
		"build": "tsdown"
	},
	"peerDependencies": {
		"@iconify/json": ">=2",
		"vite": ">=6"
	},
	"devDependencies": {
		"@iconify/json": ">=2",
		"tsdown": "^0.18.3",
		"typescript": "^5.9.3",
		"vite": ">=6"
	}
}
