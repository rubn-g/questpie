{
	"name": "questpie",
	"version": "3.0.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/questpie/questpie.git",
		"directory": "packages/questpie"
	},
	"bin": {
		"questpie": "./dist/cli.mjs"
	},
	"files": [
		"dist",
		"skills"
	],
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"imports": {
		"#questpie/*": "./src/*"
	},
	"exports": {
		".": "./src/exports/index.ts",
		"./cli": "./src/exports/cli.ts",
		"./client": "./src/exports/client.ts",
		"./drizzle": "./src/exports/drizzle.ts",
		"./drizzle-pg-core": "./src/exports/drizzle-pg-core.ts",
		"./shared": "./src/exports/shared.ts",
		"./*": "./*"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": "./dist/index.mjs",
			"./cli": "./dist/cli.mjs",
			"./client": "./dist/client.mjs",
			"./drizzle": "./dist/drizzle.mjs",
			"./drizzle-pg-core": "./dist/drizzle-pg-core.mjs",
			"./shared": "./dist/shared.mjs",
			"./*": "./*"
		}
	},
	"scripts": {
		"build": "tsdown",
		"test": "QUESTPIE_MIGRATIONS_SILENT=1 bun test",
		"test:watch": "bun test --watch",
		"check-types": "tsc --noEmit",
		"questpie:generate": "bun run ./src/exports/cli.ts generate --verbose",
		"dev": "bun run --watch src/index.ts"
	},
	"dependencies": {
		"@drepkovsky/tinydi": "^2.3.0",
		"better-auth": "^1.4.9",
		"commander": "^14.0.2",
		"drizzle-orm": "1.0.0-beta.6-4414a19",
		"flydrive": "^1.3.0",
		"html-to-text": "^9.0.5",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.3",
		"qs": "^6.13.1",
		"superjson": "^2.2.6",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@electric-sql/pglite": "^0.3.14",
		"@types/html-to-text": "^9.0.4",
		"@types/nodemailer": "^7.0.5",
		"@types/pg": "^8.16.0",
		"@types/qs": "^6.9.17",
		"@types/react": "^19.2.7",
		"bun-types": "latest",
		"drizzle-kit": "1.0.0-beta.6-4414a19",
		"ioredis": "^5.4.2",
		"nodemailer": "^7.0.12",
		"pg": "^8.13.1",
		"pg-boss": "^12.5.4",
		"tsdown": "^0.18.3"
	},
	"peerDependencies": {
		"@react-email/components": "^1.0.2",
		"@react-email/render": "^2.0.0",
		"drizzle-kit": "1.0.0-beta.6-4414a19",
		"ioredis": "^5.4.2",
		"nodemailer": "^7.0.12",
		"pg": "^8.13.1",
		"pg-boss": "^12.5.4"
	},
	"peerDependenciesMeta": {
		"@react-email/components": {
			"optional": true
		},
		"@react-email/render": {
			"optional": true
		},
		"drizzle-kit": {
			"optional": true
		},
		"ioredis": {
			"optional": true
		},
		"nodemailer": {
			"optional": true
		},
		"pg": {
			"optional": true
		},
		"pg-boss": {
			"optional": true
		}
	}
}
