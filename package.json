{
	"name": "questpie",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*",
		"examples/*"
	],
	"scripts": {
		"build": "turbo run build",
		"clean": "bun run clean:lock && bun run clean:artifacts && bun run clean:nm",
		"clean:artifacts": "bunx rimraf --glob './**/{dist,build,out,.next}'",
		"clean:lock": "bunx rimraf --glob ./**/bun.lock",
		"clean:nm": "bunx rimraf --glob ./**/node_modules",
		"dev": "turbo run dev",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"check-types": "turbo run check-types",
		"test": "QUESTPIE_MIGRATIONS_SILENT=1 bun test",
		"questpie:generate": "turbo run questpie:generate",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "turbo run build --filter='./packages/*' && bun run scripts/publish.ts",
		"validate": "bun run scripts/validate.ts",
		"validate:docs": "bun run scripts/validate-docs.ts",
		"validate:docs:report": "bun run scripts/validate-docs.ts --report"
	},
	"dependencies": {
		"@iconify/react": "^6.0.2",
		"server-only": "^0.0.1"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@iconify/json": "^2.2.452",
		"fumadocs-typescript": "^5.0.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"shadcn": "^3.6.3",
		"turbo": "^2.6.3",
		"typescript": "5.9.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.0"
}
