{
	"name": "tanstack-barbershop-example",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"imports": {
		"#questpie": "./src/questpie/server/.generated/index.ts",
		"#questpie/*": "./src/questpie/server/.generated/*"
	},
	"scripts": {
		"dev": "bun --bun vite dev",
		"dev:worker": "bun --bun run --watch ./src/worker.ts",
		"worker": "bun --bun run ./src/worker.ts",
		"generate": "bun x questpie generate -c src/questpie/server/questpie.config.ts",
		"migrate": "bun x questpie migrate:up -c src/questpie/server/questpie.config.ts",
		"migrate:down": "bun x questpie migrate:down -c src/questpie/server/questpie.config.ts",
		"migrate:status": "bun x questpie migrate:status -c src/questpie/server/questpie.config.ts",
		"migrate:generate": "bun x questpie migrate:generate -c src/questpie/server/questpie.config.ts",
		"seed": "bun x questpie seed -c src/questpie/server/questpie.config.ts",
		"seed:demo": "bun x questpie seed --category dev -c src/questpie/server/questpie.config.ts",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"e2e": "playwright test",
		"e2e:ui": "playwright test --ui",
		"e2e:debug": "playwright test --debug",
		"e2e:report": "playwright show-report",
		"lint": "oxlint",
		"format": "oxfmt",
		"check": "oxfmt && oxlint --fix"
	},
	"dependencies": {
		"@base-ui/react": "^1.0.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@hugeicons/core-free-icons": "^2.0.0",
		"@hugeicons/react": "^1.1.1",
		"@iconify/react": "^6.0.2",
		"@questpie/admin": "workspace:*",
		"@questpie/openapi": "workspace:*",
		"@tailwindcss/vite": "^4.0.6",
		"@tanstack/db": "^0.1.1",
		"@tanstack/react-devtools": "^0.7.0",
		"@tanstack/react-query": "^5.62.11",
		"@tanstack/react-router": "^1.132.0",
		"@tanstack/react-router-devtools": "^1.132.0",
		"@tanstack/react-start": "^1.132.0",
		"@tanstack/react-table": "^8.20.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "1.0.0-beta.6-4414a19",
		"nitro": "latest",
		"questpie": "workspace:*",
		"react": "^19.2.0",
		"react-day-picker": "^9.13.0",
		"react-dom": "^19.2.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.0.6",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.2.1"
	},
	"devDependencies": {
		"@iconify/json": ">=2",
		"@playwright/test": "^1.58.2",
		"@questpie/vite-plugin-iconify": "workspace:*",
		"@rolldown/plugin-babel": "^0.2.0",
		"@tanstack/devtools-vite": "^0.3.11",
		"@types/node": "^22.10.2",
		"@types/react": "^19.2.0",
		"@types/react-dom": "^19.2.0",
		"@vitejs/plugin-react": "^6.0.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"jsdom": "^27.0.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"shadcn": "^3.6.1",
		"typescript": "^5.9.2",
		"vite": "^8.0.0",
		"vitest": "^3.0.5"
	}
}
